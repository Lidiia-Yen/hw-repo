        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.variables.set(\"random_number\", String(Math.floor(Math.random()*3 + 1)));"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status code 200', function(){",
              "    pm.response.to.have.status(200)",
              "});",
              "",
              "pm.test('Returns exact number jokes', () => {",
              "    const expectedCount = parseInt(pm.variables.get(\"random_number\"), 10);",
              "    pm.expect(pm.response.json()).to.be.an('array').with.lengthOf(expectedCount);",
              "});"
            ],
