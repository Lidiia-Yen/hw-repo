          "script": {
            "exec": [
              "pm.test('status code 200', function(){\r",
              "    pm.response.to.have.status(200)\r",
              "});\r",
              "\r",
              "pm.test('Response is a non-empty array', () => {\r",
              "    const body = pm.response.json();\r",
              "    pm.expect(body).to.be.an('array').that.is.not.empty\r",
              "});\r",
              "\r",
              "pm.test('All types are strings', () => {\r",
              "    const body = pm.response.json();\r",
              "    body.forEach(type => pm.expect(type).to.be.a('string').that.is.not.empty);\r",
              "    });"
