              "});",
              "",
              "pm.test('Returned id matches requested id', () => {",
              "    pm.expect(pm.response.json().id).to.equal(pm.collectionVariables.get(\"cat_id\"))",
              "});",
              "",
              "pm.test('Returned breed matches set breed', () => {",
              "    pm.expect(pm.response.json().breeds[0].id).to.equal(pm.collectionVariables.get(\"cat_breed_id\"))",
              "});",
              "",
              "pm.test('Returned url matches saved url', () => {",
              "    pm.expect(pm.response.json().url).to.equal(pm.collectionVariables.get(\"cat_url\"))",
              "});",
              ""
